# ========================================
# App Prototype Creator - Environment Variables
# ========================================
# Copy this file to .env and fill in your values

# ----------------------------------------
# Database Configuration
# ----------------------------------------
# Mode: LOCAL (SQLDelight only), CLOUD (Firebase only), HYBRID (both)
DATABASE_MODE=LOCAL

# ----------------------------------------
# Firebase Configuration (for CLOUD or HYBRID mode)
# ----------------------------------------
# Get these values from Firebase Console > Project Settings
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_API_KEY=AIzaSy...
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abc123

# ----------------------------------------
# AI Backend Configuration
# ----------------------------------------
# Backend type: N8N or SPRING_BOOT
AI_BACKEND_TYPE=N8N

# n8n Configuration
N8N_BASE_URL=https://your-n8n-instance.com
N8N_WEBHOOK_PATH=/webhook/chat-agent
N8N_API_KEY=your-n8n-api-key

# Spring Boot AI Configuration (optional)
SPRING_BOOT_BASE_URL=http://localhost:8080
SPRING_BOOT_API_KEY=your-spring-boot-api-key

# ----------------------------------------
# App Configuration
# ----------------------------------------
DATABASE_NAME=prototype_db
DEBUG=true
DEFAULT_THEME=system
DEFAULT_LANGUAGE=es

# ----------------------------------------
# Notes
# ----------------------------------------
# - For LOCAL mode: Only DATABASE_MODE=LOCAL is required
# - For CLOUD mode: Configure Firebase credentials
# - For HYBRID mode: Configure both (requires additional implementation)
# - Firebase setup guide: See FIREBASE_SETUP.md
# - Migration guide: See FIREBASE_MIGRATION.md
