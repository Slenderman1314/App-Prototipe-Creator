
# ========================================
# App Prototype Creator - Environment Variables
# ========================================

#App Configuration
DATABASE_NAME=prototype_db
DEBUG=true
DEFAULT_THEME=system
DEFAULT_LANGUAGE=es

# ----------------------------------------
# n8n Configuration (Optional - for testing)
# ----------------------------------------
N8N_BASE_URL=your_n8n_base_url_here
N8N_WEBHOOK_PATH=your_webhook_path_here
N8N_API_KEY=your_n8n_api_key_here

# Database Configuration
# ----------------------------------------
# Mode: LOCAL (SQLDelight only), CLOUD (Firebase only)
DATABASE_MODE=LOCAL

# ----------------------------------------
# Firebase Configuration (for CLOUD)
# ----------------------------------------
# Get these values from Firebase Console > Project Settings
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_API_KEY=AIzaSy...
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abc123

# ----------------------------------------
# Notes
# ----------------------------------------
# - For LOCAL mode: Only DATABASE_MODE=LOCAL is required
# - For CLOUD mode: Configure Firebase credentials
